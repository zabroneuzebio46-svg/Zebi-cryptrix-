<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Hapa itabadilisha jina linaloonekana kwenye tab ya kivinjari (Browser) -->
    <title>Zebi Cryptrix</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #0f111a;
            font-family: 'Courier New', Courier, monospace;
        }
        .calculator {
            background-color: #1a1c23;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0px 8px 20px rgba(0,0,0,0.5);
            width: 320px;
            border: 1px solid #ff007f; /* Mstari wa pembeni wenye muonekano wa cyberpunk */
        }
        .brand-title {
            color: #ff007f;
            text-align: center;
            margin-top: 0;
            margin-bottom: 15px;
            font-size: 20px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        #display {
            width: 100%;
            height: 60px;
            background-color: #0f111a;
            border: 1px solid #333;
            color: #00ffcc; /* Rangi ya herufi za kijani/blue ya kijeshi au hacker style */
            text-align: right;
            padding: 10px;
            font-size: 26px;
            border-radius: 8px;
            margin-bottom: 20px;
            box-sizing: border-box;
        }
        .buttons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }
        button {
            padding: 18px;
            font-size: 18px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            background-color: #252836;
            color: white;
            transition: 0.2s;
        }
        button:hover { background-color: #313547; }
        .operator { background-color: #ff007f; color: white; }
        .operator:hover { background-color: #e0006c; }
        .clear { background-color: #3b3f54; color: #ff007f; }
        .clear:hover { background-color: #4a4f6a; }
    </style>
</head>
<body>

<div class="calculator">
    <!-- Hapa ndio jina linaonekana juu ya Kikokotoo chako -->
    <h2 class="brand-title">Zebi Cryptrix</h2>
    
    <input type="text" id="display" readonly>
    <div class="buttons">
        <button class="clear" onclick="clearDisplay()">C</button>
        <button onclick="appendValue('/')">/</button>
        <button onclick="appendValue('*')">*</button>
        <button onclick="appendValue('-')">-</button>
        
        <button onclick="appendValue('7')">7</button>
        <button onclick="appendValue('8')">8</button>
        <button onclick="appendValue('9')">9</button>
        <button class="operator" onclick="appendValue('+')">+</button>
        
        <button onclick="appendValue('4')">4</button>
        <button onclick="appendValue('5')">5</button>
        <button onclick="appendValue('6')">6</button>
        <button class="operator" onclick="calculate()">?</button> 
        
        <button onclick="appendValue('1')">1</button>
        <button onclick="appendValue('2')">2</button>
        <button onclick="appendValue('3')">3</button>
        <button onclick="appendValue('0')">0</button>
    </div>
</div>

<script>
    const display = document.getElementById('display');

    function appendValue(val) {
        display.value += val;
    }

    function clearDisplay() {
        display.value = '';
    }

    function calculate() {
        try {
            display.value = eval(display.value);
        } catch (error) {
            display.value = 'Error';
        }
    }
</script>

</body>
</html>
